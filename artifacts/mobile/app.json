{
  "expo": {
    "name": "SiteTrack",
    "slug": "sitetrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sitetrack",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060914"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.butaddei.sitetrack",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "SiteTrack uses your photo library so you can set a profile photo.",
        "NSCameraUsageDescription": "SiteTrack uses your camera so you can take a profile photo.",
        "NSPhotoLibraryAddUsageDescription": "SiteTrack saves photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sitetrack.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://sitetrack.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "SiteTrack uses your photo library so you can set a profile photo.",
          "cameraPermission": "SiteTrack uses your camera so you can take a profile photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "cc190c3c-e02a-4c35-9c64-7f1d7ed403eb"
      }
    }
  }
}
